# Wallet private key for the agent / API server
AGENT_PRIVATE_KEY=0x...

# 0G Chain RPC endpoint
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage indexer node
OG_STORAGE_NODE=https://indexer-storage-testnet.0g.ai

# Deployed contract addresses (from mnemos-contract Deploy.s.sol output)
REGISTRY_ADDRESS=0x...
MARKETPLACE_ADDRESS=0x...

# NestJS API port (optional, defaults to 3001)
PORT=3001
