{
  "name": "@mnemos-sdk/sdk",
  "version": "0.1.3",
  "description": "SDK for storing, registering, and trading agent memory on 0G Storage and EVM",
  "license": "MIT",
  "keywords": [
    "ai-agent",
    "memory",
    "0g-storage",
    "blockchain",
    "evm",
    "viem"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "example": "tsx examples/basic-integration.ts",
    "example:customer": "tsx examples/customer-integration.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "viem": "^2.9.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "peerDependencies": {
    "@0gfoundation/0g-ts-sdk": "*"
  },
  "peerDependenciesMeta": {
    "@0gfoundation/0g-ts-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "dotenv": "^16.4.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0"
  }
}
